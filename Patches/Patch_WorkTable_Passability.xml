<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<!-- Fix: pawns freely walk through worktables (SK_WorkTable has PassThroughOnly but no pathCost) -->
	<!-- Add high pathCost so pawns prefer to walk around, but can still pass in emergencies -->
	<Operation Class="PatchOperationAdd">
		<xpath>Defs/ThingDef[@Name="SK_WorkTable"]</xpath>
		<value>
			<pathCost>70</pathCost>
		</value>
	</Operation>

</Patch>
